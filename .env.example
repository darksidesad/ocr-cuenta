# === OPENROUTER / LLM ===
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# === AUTH (JWT) ===
APP_USERNAME=admin
APP_PASSWORD=          # Contraseña para login — NUNCA committear
JWT_SECRET_KEY=        # Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_EXPIRE_MINUTES=480

# === DATABASE ===
DATABASE_URL=postgresql+asyncpg://facturas_user:change_me@localhost:5432/facturas_db

# === APP ===
MAX_FILE_SIZE_MB=10
ENVIRONMENT=development
